<Window x:Class="AdobeDownloader.App.UninstallWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="AppIcon.ico"
        Title="Adobe Downloader — 卸载已安装程序" Height="620" Width="720"
        Background="{StaticResource Bg}" FontFamily="Segoe UI, Microsoft YaHei UI"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <Path Data="{StaticResource IconUninstall}" Width="22" Height="22" Stretch="Uniform"
                      Fill="{StaticResource Accent}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="卸载已安装的 Adobe 程序" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Text="下列为本机检测到的 Adobe 程序（软件启动时已后台扫描）。可单独卸载某个版本，卸载会调用该程序自带的卸载器并请求管理员权限。"
                       Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,4,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Background="{StaticResource Panel}" CornerRadius="10" Padding="10">
            <Grid>
                <TextBlock x:Name="EmptyHint" Text="未检测到已安装的 Adobe 程序"
                           Foreground="{StaticResource Muted}" HorizontalAlignment="Center"
                           VerticalAlignment="Center" Visibility="Collapsed"/>
                <ListBox x:Name="AppList" BorderThickness="0" Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Margin" Value="0,3"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#FAFAFB" BorderBrush="#ECECEF" BorderThickness="1"
                                    CornerRadius="8" Padding="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="44" Height="44" Margin="0,0,12,0"
                                            CornerRadius="8" Background="#F0F0F3" VerticalAlignment="Center">
                                        <Image Width="34" Height="34" Source="{Binding Icon}"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="14"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Version}" Foreground="{StaticResource Muted}"
                                                   FontSize="12" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="{Binding SizeText}" Foreground="{StaticResource Muted}"
                                               FontSize="12" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Content="卸载" Click="OnUninstall" Tag="{Binding}"
                                                IsEnabled="{Binding CanUninstall}" Padding="16,6"/>
                                        <Button Content="强制删除" Click="OnForceRemove" Tag="{Binding}"
                                                Visibility="{Binding CanForceRemove, Converter={StaticResource BoolToVisible}}"
                                                Padding="12,6" Margin="0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="StatusText" Foreground="{StaticResource Muted}" VerticalAlignment="Center"/>
            <Button Grid.Column="1" x:Name="RescanButton" Content="⟳ 重新扫描" Click="OnRescan"
                    Style="{StaticResource PrimaryButton}" Padding="18,7" Margin="0"/>
        </Grid>
    </Grid>
</Window>
