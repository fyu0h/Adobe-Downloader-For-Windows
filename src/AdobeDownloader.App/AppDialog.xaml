<Window x:Class="AdobeDownloader.App.AppDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" ShowInTaskbar="False" SizeToContent="Height"
        Width="440" WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI, Microsoft YaHei UI">
    <Border Margin="16" Background="{StaticResource Panel}" CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.22" Color="#000000"/>
        </Border.Effect>
        <Grid Margin="22,20,22,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题行：图标 + 标题 -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                <Border x:Name="IconBadge" Width="28" Height="28" CornerRadius="14"
                        Margin="0,0,10,0" VerticalAlignment="Center" Visibility="Collapsed">
                    <TextBlock x:Name="IconGlyph" Foreground="White" FontSize="16" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock x:Name="TitleText" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>

            <!-- 正文（过长内容可滚动） -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="360" Margin="0,0,0,18">
                <TextBlock x:Name="MessageText" TextWrapping="Wrap" LineHeight="21"
                           Foreground="#3A3A40" FontSize="13.5"/>
            </ScrollViewer>

            <!-- 按钮 -->
            <StackPanel Grid.Row="2" x:Name="ButtonPanel" Orientation="Horizontal" HorizontalAlignment="Right"/>
        </Grid>
    </Border>
</Window>
