<Window x:Class="AdobeDownloader.App.UninstallRunWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="AppIcon.ico"
        Title="Adobe Downloader — 卸载" Height="440" Width="700"
        Background="{StaticResource Bg}" FontFamily="Segoe UI, Microsoft YaHei UI"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="TitleText" Text="正在卸载..." FontSize="18" FontWeight="Bold"/>
        <TextBlock Grid.Row="1" x:Name="StatusText" Text="准备中" Foreground="{StaticResource Muted}" Margin="0,6,0,10"/>
        <ProgressBar Grid.Row="2" x:Name="Bar" Height="8" Minimum="0" Maximum="100"
                     Foreground="{StaticResource Accent}" Background="#E6E6EA" BorderThickness="0"/>

        <Border Grid.Row="3" Margin="0,14,0,0" Background="#FFFFFF" CornerRadius="8" Padding="10">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="卸载日志（删除快捷方式、安装目录、系统卸载项）"
                           FontWeight="SemiBold" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,0,0,6"/>
                <TextBox x:Name="LogBox" IsReadOnly="True" BorderThickness="0" Background="Transparent"
                         TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas, Cascadia Mono" FontSize="12"/>
            </DockPanel>
        </Border>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="CloseButton" Content="关闭" Click="OnClose" IsEnabled="False" Padding="18,7"/>
        </StackPanel>
    </Grid>
</Window>
